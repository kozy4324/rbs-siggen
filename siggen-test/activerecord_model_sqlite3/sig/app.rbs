end

class AccountIdAliasTest < ::ActiveSupport::TestCase
end

class ArticleIdTest < ::ActiveSupport::TestCase
end

class PostTagIdFalseTest < ::ActiveSupport::TestCase
end

class PostTagPostIdTest < ::ActiveSupport::TestCase
end

class PostTagTagNameTest < ::ActiveSupport::TestCase
end

class TaggingIdTest < ::ActiveSupport::TestCase
end

class TaggingPostIdTest < ::ActiveSupport::TestCase
end

class TaggingTagIdTest < ::ActiveSupport::TestCase
end
