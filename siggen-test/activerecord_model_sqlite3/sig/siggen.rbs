    def find_sole_by: (?id: Array[untyped]? | Array[Array[untyped]?], ?context: ::String? | Array[::String], ?post_id: ::Integer? | Array[::Integer], ?tag_id: ::Integer? | Array[::Integer]) -> Tagging
                    | (untyped arg, *untyped args) -> Tagging
                    | (Array[untyped]) -> Tagging

    # Find the first record (or first N records if a parameter is supplied).
    # If no order is defined it will order by primary key.
    #
    # ```ruby
    #   Person.first # returns the first object fetched by SELECT * FROM people ORDER BY people.id LIMIT 1
    #   Person.where(["user_name = ?", user_name]).first
    #   Person.where(["user_name = :u", { u: user_name }]).first
    #   Person.order("created_on DESC").offset(5).first
    #   Person.first(3) # returns the first three objects fetched by SELECT * FROM people ORDER BY people.id LIMIT 3
    # ```
