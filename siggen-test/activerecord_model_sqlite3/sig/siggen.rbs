    def new: (?id: Integer?, ?created_at: (::ActiveSupport::TimeWithZone | ::Time)?, ?name: ::String?, ?updated_at: (::ActiveSupport::TimeWithZone | ::Time)?) ?{ (Author) -> void } -> Author

