    def first_or_create!: (?id: Integer?, ?created_at: (::ActiveSupport::TimeWithZone | ::Time)?, ?name: ::String?, ?updated_at: (::ActiveSupport::TimeWithZone | ::Time)?) ?{ (Author) -> void } -> Author

