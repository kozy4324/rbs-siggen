                | (Array[{ ?id: Integer?, ?author_id: ::Integer?, ?avatar_url: ::String?, ?bio: ::String?, ?created_at: (::ActiveSupport::TimeWithZone | ::Time)?, ?updated_at: (::ActiveSupport::TimeWithZone | ::Time)?, ?website_url: ::String? }]) ?{ (instance) -> void } -> Array[instance]

  # Creates an object (or multiple objects) and saves it to the database, if validations pass.
