    # ```
    #
    # For other attributes it will return +true+ if the value is present
    # and return +false+ otherwise:
    #
    # ```ruby
    #   product.name = nil
    #   product.name? # => false
    #   product.name = " "
    #   product.name? # => false
    #   product.name = "Orange"
    #   product.name? # => true
    # ```
